        <!-- ECS → S3 user uploads -->
        <mxCell id="e-ecs-s3uploads" value="presigned URL" style="endArrow=classic;html=1;rounded=0;strokeColor=#7AA116;strokeWidth=2;fontSize=14;" edge="1" parent="aws-cloud" source="ecs-svc" target="s3-uploads">

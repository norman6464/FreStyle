        <!-- GitHub Actions → IAM -->
        <mxCell id="e-gh-iam" value="OIDC" style="endArrow=classic;html=1;rounded=0;strokeColor=#232F3E;strokeWidth=2;fontSize=14;" edge="1" parent="1" source="ext-gh" target="iam">

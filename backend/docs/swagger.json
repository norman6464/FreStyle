                "produces": [
                    "application/json"
                ],
                "tags": [
                    "notifications"
                ],
                "summary": "未読 通知 数",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    "400": {
                        "description": "DB 失敗",
                        "schema": {
                            "$ref": "#/definitions/internal_handler.errorResponse"
                        }
                    },
                    "401": {
                        "description": "未 認証",
                        "schema": {
                            "$ref": "#/definitions/internal_handler.errorResponse"
                        }
                    }
                }
            }
        },
        "/notifications/{id}/read": {
            "patch": {
                "security": [
                    {
                        "CookieAuth": []
                    }
                ],
                "description": "指定 通知 を 既読 に する (所有者 検証 込み)。 PATCH / PUT 両方 受け付ける。",

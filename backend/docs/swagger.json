                    "application/json"
                ],
                "tags": [
                    "notifications"
                ],
                "summary": "通知 一覧",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/github_com_norman6464_FreStyle_backend_internal_domain.Notification"
                            }
                        }
                    },
                    "400": {
                        "description": "DB 取得 失敗",
                        "schema": {
                            "$ref": "#/definitions/internal_handler.errorResponse"
                        }
                    },
                    "401": {
                        "description": "未 認証",
                        "schema": {
                            "$ref": "#/definitions/internal_handler.errorResponse"
                        }
                    }
                }
            }
        },
